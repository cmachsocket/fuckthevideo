<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      LSPosed 作用域。

      留空或 *  = 所有应用
      列出包名    = 只 hook 列出的应用

      推荐在 release 前明确列出,避免在系统进程(如 com.android.systemui)
      加载时 hook Activity.onCreate 把系统卡死。
    -->
    <string-array name="xposed_scope" translatable="false">
        <item>*</item>
    </string-array>
</resources>
